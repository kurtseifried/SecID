{
  "schema_version": "1.0",
  "namespace": "mlcommons.org",
  "type": "control",
  "status": "draft",
  "status_notes": null,

  "official_name": "MLCommons",
  "common_name": "MLCommons",
  "alternate_names": null,
  "notes": "MLCommons produces AI safety benchmarks, the Croissant dataset format, and MLPerf performance benchmarks.",
  "wikidata": null,
  "wikipedia": null,

  "urls": [
    {"type": "website", "url": "https://mlcommons.org"}
  ],

  "match_nodes": [
    {
      "patterns": ["(?i)^ai-safety$"],
      "description": "MLCommons AI Safety benchmarks and hazard taxonomy",
      "weight": 100,
      "data": {
        "urls": [
          {"type": "website", "url": "https://mlcommons.org/working-groups/ai-safety"},
          {"type": "benchmarks", "url": "https://mlcommons.org/benchmarks/ai-safety"}
        ],
        "examples": ["hazard-taxonomy", "benchmark"]
      }
    },
    {
      "patterns": ["(?i)^croissant$"],
      "description": "Croissant dataset metadata format",
      "weight": 100,
      "data": {
        "urls": [
          {"type": "website", "url": "https://mlcommons.org/croissant"},
          {"type": "github", "url": "https://github.com/mlcommons/croissant"}
        ],
        "versions_available": [
          {"version": "1.0", "release_date": null, "status": "current", "note": "First release of Croissant metadata format."}
        ],
        "examples": []
      }
    },
    {
      "patterns": ["(?i)^mlperf$"],
      "description": "MLPerf performance benchmarks for ML systems",
      "weight": 100,
      "data": {
        "urls": [
          {"type": "website", "url": "https://mlcommons.org/benchmarks"}
        ],
        "examples": ["training", "inference"]
      }
    }
  ]
}
