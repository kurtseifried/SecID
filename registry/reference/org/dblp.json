      "data": {
        "official_name": "DBLP Record",
        "common_name": null,
        "alternate_names": null,
        "description": "DBLP bibliographic record identified by venue type and path.",
        "notes": "DBLP record IDs encode the venue type (conf, journals, books, etc.), the venue abbreviation, and the author/year. The path format mirrors the DBLP URL structure.",
