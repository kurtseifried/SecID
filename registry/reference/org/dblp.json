        "examples": [
          {"input": "conf/ccs/SmithJ23", "url": "https://dblp.org/rec/conf/ccs/SmithJ23", "note": "CCS conference paper"},
          {"input": "journals/tissec/AndersonR01", "url": "https://dblp.org/rec/journals/tissec/AndersonR01", "note": "TISSEC journal paper"}
