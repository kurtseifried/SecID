      "weight": 100,
      "data": {
        "official_name": "International Standard Book Number",
        "common_name": "ISBN-13",
        "alternate_names": null,
        "description": "ISBN-13 book identifier, optionally formatted with dashes.",
        "notes": "ISBN-13 replaced ISBN-10 as the standard format in 2007. The prefix 978 or 979 is the EAN bookland code. Group, publisher, and title segments vary in length. WorldCat provides a universal catalog lookup.",
        "urls": [
          {"type": "website", "url": "https://www.isbn-international.org"},
          {"type": "lookup", "url": "https://www.worldcat.org/isbn/{id}"}
        ],
        "examples": [
          {"input": "978-0-13-468599-1", "url": "https://www.worldcat.org/isbn/978-0-13-468599-1", "note": "ISBN with dashes"},
